    },
    {
      "id": "invalid_token_grammar",
      "expected": "rejected",
      "reason": "INVALID_TOKEN",
      "text": "Response.\nPMM-CONTROL:{\"schema\":\"pmm.control.v1\",\"concepts\":[\"Identity Adaptive Continuity\"]}"
    },
    {
      "id": "undefined_without_definition",
      "expected": "rejected",
      "reason": "UNDEFINED_CONCEPT",
      "text": "Response.\nPMM-CONTROL:{\"schema\":\"pmm.control.v1\",\"concepts\":[\"continuity.unknown\"]}"
    },
    {
      "id": "dangling_definition",
      "expected": "rejected",
      "reason": "UNGROUNDED_DEFINITION",
      "text": "Response.\nPMM-CONTROL:{\"schema\":\"pmm.control.v1\",\"concepts\":[\"identity.continuity\"],\"define\":[{\"token\":\"continuity.dangling\",\"definition\":\"A definition deposited without grounding in the current turn concepts list.\"}]}"
    },
    {
      "id": "redefinition_existing",
      "expected": "rejected",
      "reason": "REDEFINITION",
      "text": "Response.\nPMM-CONTROL:{\"schema\":\"pmm.control.v1\",\"concepts\":[\"identity.continuity\"],\"define\":[{\"token\":\"identity.continuity\",\"definition\":\"An attempted replacement definition for an existing concept token.\"}]}"
    },
    {
      "id": "duplicate_definition",
      "expected": "rejected",
      "reason": "DUPLICATE_DEFINITION",
      "text": "Response.\nPMM-CONTROL:{\"schema\":\"pmm.control.v1\",\"concepts\":[\"continuity.new_relation\"],\"define\":[{\"token\":\"continuity.new_relation\",\"definition\":\"The first definition for a newly grounded relational concept in this turn.\"},{\"token\":\"continuity.new_relation\",\"definition\":\"The second conflicting definition for the same newly grounded concept token.\"}]}"
    },
    {
      "id": "unknown_definition_key",
      "expected": "rejected",
      "reason": "UNKNOWN_DEFINITION_KEYS",
      "text": "Response.\nPMM-CONTROL:{\"schema\":\"pmm.control.v1\",\"concepts\":[\"continuity.new_relation\"],\"define\":[{\"token\":\"continuity.new_relation\",\"definition\":\"A properly grounded definition that also attempts an unauthorized relation.\",\"alias\":\"continuity.other\"}]}"
    },
    {
      "id": "definition_too_short",
      "expected": "rejected",
      "reason": "INVALID_DEFINITION",
      "text": "Response.\nPMM-CONTROL:{\"schema\":\"pmm.control.v1\",\"concepts\":[\"continuity.short\"],\"define\":[{\"token\":\"continuity.short\",\"definition\":\"Too short.\"}]}"
    },
    {
      "id": "legacy_header_only",
      "expected": "accepted",
      "text": "{\"concepts\":[\"identity.continuity\"]}\nNatural response."
    },
    {
      "id": "dual_identical",
      "expected": "accepted",
      "text": "{\"concepts\":[\"identity.continuity\"]}\nNatural response.\nPMM-CONTROL:{\"schema\":\"pmm.control.v1\",\"concepts\":[\"identity.continuity\"]}"
    },
    {
      "id": "dual_conflict",
      "expected": "rejected",
      "reason": "DUAL_CHANNEL_CONFLICT",
      "text": "{\"concepts\":[\"memory.persistence\"]}\nNatural response.\nPMM-CONTROL:{\"schema\":\"pmm.control.v1\",\"concepts\":[\"identity.continuity\"]}"
    },
    {
      "id": "plain_prose",
      "expected": "no_declaration",
      "text": "A discussion of identity.adaptive_continuity in unrestricted prose must remain inert."
    },
    {
      "id": "unrelated_final_json",
      "expected": "no_declaration",
      "text": "Application response.\n{\"concepts\":[\"identity.continuity\"],\"application\":true}"
    }
  ]
