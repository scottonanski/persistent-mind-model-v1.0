    },
    {
      "id": "oversized_control",
      "expected": "rejected",
      "reason": "ENVELOPE_TOO_LARGE",
      "generator": "oversized_definition"
    },
    {
      "id": "wrong_schema",
      "expected": "rejected",
      "reason": "INVALID_SCHEMA",
      "text": "Response.\nPMM-CONTROL:{\"schema\":\"pmm.control.v2\",\"concepts\":[\"identity.continuity\"]}"
    },
    {
      "id": "unknown_key",
      "expected": "rejected",
      "reason": "UNKNOWN_KEYS",
      "text": "Response.\nPMM-CONTROL:{\"schema\":\"pmm.control.v1\",\"concepts\":[\"identity.continuity\"],\"relate\":[]}"
    },
    {
      "id": "empty_concepts",
      "expected": "rejected",
      "reason": "INVALID_CONCEPTS",
